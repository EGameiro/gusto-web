@page
@model GustoConvenio.Web.Pages.Login.IndexModel
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">🍽️ GUSTO Convênio</div>
        <div class="login-sub">Acesso exclusivo para empresas conveniadas</div>

        <form method="post">
            <div class="form-group">
                <label class="form-label">E-mail</label>
                <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Senha</label>
                <input asp-for="Senha" class="form-control" type="password" autocomplete="current-password" />
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.Erro))
            {
                <div class="alert alert-danger">@Model.Erro</div>
            }

            <button type="submit" class="btn btn-primary" style="width:100%; margin-top:8px; justify-content:center;">
                Entrar
            </button>
        </form>
    </div>
</div>
