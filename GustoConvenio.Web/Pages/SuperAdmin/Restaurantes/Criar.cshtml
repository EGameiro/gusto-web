@page
@model GustoConvenio.Web.Pages.SuperAdmin.Restaurantes.CriarModel
@{
    ViewData["Title"] = "Novo Restaurante";
}

<div class="page-title">Novo Restaurante</div>
<div class="page-sub">Cadastre um novo restaurante no sistema</div>

<div class="form-card">
    <form method="post">
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Nome *</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Slug * <small style="color:#888;">(ex: gusto, restaurante-x)</small></label>
                <input asp-for="Slug" class="form-control" />
                <span asp-validation-for="Slug" class="text-danger"></span>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Telefone</label>
                <input asp-for="Telefone" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Endereço</label>
            <input asp-for="Endereco" class="form-control" />
        </div>

        <hr style="margin:20px 0;" />
        <div class="page-sub" style="margin-bottom:12px;">Primeiro administrador</div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Nome do Admin *</label>
                <input asp-for="AdminNome" class="form-control" />
                <span asp-validation-for="AdminNome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Email do Admin *</label>
                <input asp-for="AdminEmail" type="email" class="form-control" />
                <span asp-validation-for="AdminEmail" class="text-danger"></span>
            </div>
        </div>
        <div class="form-group" style="max-width:300px;">
            <label class="form-label">Senha do Admin *</label>
            <input asp-for="AdminSenha" type="password" class="form-control" />
            <span asp-validation-for="AdminSenha" class="text-danger"></span>
        </div>

        <div style="display:flex; gap:10px; margin-top:8px;">
            <button type="submit" class="btn btn-primary">Criar restaurante</button>
            <a href="/SuperAdmin/Restaurantes" class="btn">Cancelar</a>
        </div>
    </form>
</div>
