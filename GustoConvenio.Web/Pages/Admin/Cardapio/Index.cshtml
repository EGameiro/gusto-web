@page
@model GustoConvenio.Web.Pages.Admin.Cardapio.IndexModel
@{
    ViewData["Title"] = "Cardápio";
    var pratos  = Model.Itens.Where(i => i.Tipo == "prato").ToList();
    var acomps  = Model.Itens.Where(i => i.Tipo == "acompanhamento").ToList();
}

<div class="page-title">Cardápio da semana</div>
<div class="page-sub">Gerencie os pratos e acompanhamentos por dia</div>

<!-- Tabs de dias -->
<div class="day-tabs">
    @for (int d = 0; d < Model.NomesDias.Length; d++)
    {
        var cls = d == Model.DiaAtivo ? "day-tab active" : "day-tab";
        <a href="?dia=@d" class="@cls">@Model.NomesDias[d]</a>
    }
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:16px; align-items:start;">

    <!-- Pratos -->
    <div>
        <div class="section-card-title">Pratos</div>
        <div class="table-wrap" style="margin-bottom:10px;">
            <table class="data-table">
                <tbody>
                    @foreach (var p in pratos)
                    {
                        <tr>
                            <td>@p.Nome</td>
                            <td style="width:70px; text-align:right;">
                                <form method="post" asp-page-handler="Excluir" style="display:inline;">
                                    <input type="hidden" name="id"  value="@p.Id" />
                                    <input type="hidden" name="dia" value="@Model.DiaAtivo" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Remover este prato?')">✕</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!pratos.Any())
                    {
                        <tr><td style="color:#aaa; font-size:12px; text-align:center; padding:14px;">Nenhum prato cadastrado</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Add prato -->
        <form method="post" asp-page-handler="Adicionar" style="display:flex; gap:8px;">
            <input type="hidden" name="DiaSemana" value="@Model.DiaAtivo" />
            <input type="hidden" name="Tipo"      value="prato" />
            <input type="hidden" name="Ordem"     value="0" />
            <input name="Nome" class="form-control" placeholder="Nome do prato" style="flex:1;" required maxlength="200" />
            <button type="submit" class="btn btn-primary">+ Adicionar</button>
        </form>
    </div>

    <!-- Acompanhamentos -->
    <div>
        <div class="section-card-title">Acompanhamentos</div>
        <div class="table-wrap" style="margin-bottom:10px;">
            <table class="data-table">
                <tbody>
                    @foreach (var a in acomps)
                    {
                        <tr>
                            <td>@a.Nome</td>
                            <td style="width:70px; text-align:right;">
                                <form method="post" asp-page-handler="Excluir" style="display:inline;">
                                    <input type="hidden" name="id"  value="@a.Id" />
                                    <input type="hidden" name="dia" value="@Model.DiaAtivo" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Remover este acompanhamento?')">✕</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!acomps.Any())
                    {
                        <tr><td style="color:#aaa; font-size:12px; text-align:center; padding:14px;">Nenhum acompanhamento cadastrado</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Add acompanhamento -->
        <form method="post" asp-page-handler="Adicionar" style="display:flex; gap:8px;">
            <input type="hidden" name="DiaSemana" value="@Model.DiaAtivo" />
            <input type="hidden" name="Tipo"      value="acompanhamento" />
            <input type="hidden" name="Ordem"     value="0" />
            <input name="Nome" class="form-control" placeholder="Nome do acompanhamento" style="flex:1;" required maxlength="200" />
            <button type="submit" class="btn btn-primary">+ Adicionar</button>
        </form>
    </div>
</div>

@section Scripts {
<style>
.day-tabs { display:flex; gap:4px; border-bottom:2px solid #eee; padding-bottom:0; }
.day-tab {
    padding: 8px 16px; border-radius: 6px 6px 0 0; font-size: 13px;
    font-weight: 500; color: #666; text-decoration:none;
    border: 1px solid transparent; border-bottom: none;
    background: transparent; cursor: pointer;
}
.day-tab:hover  { background: #f5f5f5; color: #333; }
.day-tab.active { background: #fff; color: #e8a020; border-color: #eee; border-bottom-color: #fff; margin-bottom: -2px; }
.section-card-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #888; margin-bottom: 8px; }
.btn-danger { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }
.btn-danger:hover { background: #fca5a5; }
</style>
}
