@page
@model GustoConvenio.Web.Pages.Admin.Cardapio.IndexModel
@{
    ViewData["Title"] = "Cardápio";
    var pratos = Model.Itens.Where(i => i.Tipo == "prato").ToList();
    var acomps = Model.Itens.Where(i => i.Tipo == "acompanhamento").ToList();
    var empresaIdParam = Model.WhatsAppAtivo ? "whatsapp" : Model.EmpresaAtiva?.ToString();
}

<div class="page-title">Cardápio da semana</div>
<div class="page-sub">Gerencie os pratos e acompanhamentos por dia e empresa</div>

<!-- Seleção de empresa -->
<div style="margin-bottom:16px;">
    <form method="get" style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
        <input type="hidden" name="dia" value="@Model.DiaAtivo" />
        <label style="font-weight:600; font-size:13px;">Cardápio:</label>
        <select name="empresaId" class="form-control" style="width:280px;" onchange="this.form.submit()">
            <option value="">— Selecione —</option>
            @if (Model.EmpresaAtiva == null && Model.WhatsAppAtivo)
            {
                <option value="whatsapp" selected>📱 Cardápio WhatsApp</option>
            }
            else
            {
                <option value="whatsapp">📱 Cardápio WhatsApp</option>
            }
            @foreach (var e in Model.Empresas)
            {
                if (Model.EmpresaAtiva == e.Id)
                {
                    <option value="@e.Id" selected>🏢 @e.NomeEmpresa</option>
                }
                else
                {
                    <option value="@e.Id">🏢 @e.NomeEmpresa</option>
                }
            }
        </select>
        @if (Model.EmpresaAtiva.HasValue || Model.WhatsAppAtivo)
        {
            <a href="?dia=@Model.DiaAtivo" class="btn btn-sm" style="background:#f5f5f5; color:#666;">✕ Limpar</a>
        }
    </form>
</div>

@if (!Model.EmpresaAtiva.HasValue && !Model.WhatsAppAtivo)
{
    <div style="background:#fff8e1; border:1px solid #ffe082; border-radius:8px; padding:16px; color:#7a6000; font-size:13px;">
        ⚠ Selecione um cardápio para visualizar e editar.
    </div>
}
else
{
    <!-- Tabs de dias -->
    <div class="day-tabs">
        @for (int d = 0; d < Model.NomesDias.Length; d++)
        {
            var cls = d == Model.DiaAtivo ? "day-tab active" : "day-tab";
            <a href="?dia=@d&empresaId=@empresaIdParam" class="@cls">@Model.NomesDias[d]</a>
        }
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:16px; align-items:start;">

        <!-- Pratos -->
        <div>
            <div class="section-card-title">Pratos</div>
            <div class="table-wrap" style="margin-bottom:10px;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th style="width:80px; text-align:right;">Mini</th>
                            <th style="width:80px; text-align:right;">Normal</th>
                            <th style="width:90px; text-align:right;">Executiva</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in pratos)
                        {
                            <tr>
                                <td>@p.Nome</td>
                                <td style="text-align:right;">@(p.PrecoMini.HasValue ? "R$ " + p.PrecoMini.Value.ToString("N2") : "—")</td>
                                <td style="text-align:right;">@(p.PrecoNormal.HasValue ? "R$ " + p.PrecoNormal.Value.ToString("N2") : "—")</td>
                                <td style="text-align:right; font-weight:600;">@(p.PrecoExecutiva.HasValue ? "R$ " + p.PrecoExecutiva.Value.ToString("N2") : "—")</td>
                                <td style="text-align:right;">
                                    <form method="post" asp-page-handler="Excluir" style="display:inline;">
                                        <input type="hidden" name="id"        value="@p.Id" />
                                        <input type="hidden" name="dia"       value="@Model.DiaAtivo" />
                                        <input type="hidden" name="empresaId" value="@empresaIdParam" />
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Remover este prato?')">✕</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!pratos.Any())
                        {
                            <tr><td colspan="5" style="color:#aaa; font-size:12px; text-align:center; padding:14px;">Nenhum prato cadastrado</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Add prato -->
            <form method="post" asp-page-handler="Adicionar" style="display:grid; grid-template-columns:1fr repeat(3,90px) auto; gap:8px; align-items:end;">
                <input type="hidden" name="DiaSemana"  value="@Model.DiaAtivo" />
                <input type="hidden" name="Tipo"       value="prato" />
                <input type="hidden" name="Ordem"      value="0" />
                <input type="hidden" name="EmpresaId"  value="@Model.EmpresaAtiva" />
                <input type="hidden" name="IsWhatsApp" value="@Model.WhatsAppAtivo.ToString().ToLower()" />
                <div>
                    <label style="font-size:11px;color:#888;">Nome do prato</label>
                    <input name="Nome" class="form-control" placeholder="Ex: Carne Assada" required maxlength="200" />
                </div>
                <div>
                    <label style="font-size:11px;color:#888;">Mini</label>
                    <input name="PrecoMini" class="form-control" placeholder="0,00" type="number" step="0.01" min="0" />
                </div>
                <div>
                    <label style="font-size:11px;color:#888;">Normal</label>
                    <input name="PrecoNormal" class="form-control" placeholder="0,00" type="number" step="0.01" min="0" />
                </div>
                <div>
                    <label style="font-size:11px;color:#888;">Executiva</label>
                    <input name="PrecoExecutiva" class="form-control" placeholder="0,00" type="number" step="0.01" min="0" />
                </div>
                <button type="submit" class="btn btn-primary" style="height:38px;">+ Adicionar</button>
            </form>
        </div>

        <!-- Acompanhamentos -->
        <div>
            <div class="section-card-title">Acompanhamentos</div>
            <div class="table-wrap" style="margin-bottom:10px;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th style="width:90px; text-align:right;">Preço</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in acomps)
                        {
                            <tr>
                                <td>@a.Nome</td>
                                <td style="text-align:right; font-weight:600;">
                                    @(a.Preco.HasValue ? "R$ " + a.Preco.Value.ToString("N2") : "—")
                                </td>
                                <td style="text-align:right;">
                                    <form method="post" asp-page-handler="Excluir" style="display:inline;">
                                        <input type="hidden" name="id"        value="@a.Id" />
                                        <input type="hidden" name="dia"       value="@Model.DiaAtivo" />
                                        <input type="hidden" name="empresaId" value="@empresaIdParam" />
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Remover este acompanhamento?')">✕</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!acomps.Any())
                        {
                            <tr><td colspan="3" style="color:#aaa; font-size:12px; text-align:center; padding:14px;">Nenhum acompanhamento cadastrado</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Add acompanhamento -->
            <form method="post" asp-page-handler="Adicionar" style="display:flex; gap:8px; flex-wrap:wrap;">
                <input type="hidden" name="DiaSemana" value="@Model.DiaAtivo" />
                <input type="hidden" name="Tipo"      value="acompanhamento" />
                <input type="hidden" name="Ordem"     value="0" />
                <input type="hidden" name="EmpresaId" value="@Model.EmpresaAtiva" />
                <input type="hidden" name="IsWhatsApp" value="@Model.WhatsAppAtivo.ToString().ToLower()" />
                <input name="Nome"  class="form-control" placeholder="Nome do acompanhamento" style="flex:2; min-width:140px;" required maxlength="200" />
                <input name="Preco" class="form-control" placeholder="Preço (ex: 5,00)" type="number" step="0.01" min="0" style="width:120px;" />
                <button type="submit" class="btn btn-primary">+ Adicionar</button>
            </form>
        </div>
    </div>
}

@section Scripts {
<style>
.day-tabs { display:flex; gap:4px; border-bottom:2px solid #eee; padding-bottom:0; }
.day-tab {
    padding: 8px 16px; border-radius: 6px 6px 0 0; font-size: 13px;
    font-weight: 500; color: #666; text-decoration:none;
    border: 1px solid transparent; border-bottom: none;
    background: transparent; cursor: pointer;
}
.day-tab:hover  { background: #f5f5f5; color: #333; }
.day-tab.active { background: #fff; color: #e8a020; border-color: #eee; border-bottom-color: #fff; margin-bottom: -2px; }
.section-card-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #888; margin-bottom: 8px; }
.btn-danger { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }
.btn-danger:hover { background: #fca5a5; }
</style>
}
