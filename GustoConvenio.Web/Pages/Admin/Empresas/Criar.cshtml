@page
@model GustoConvenio.Web.Pages.Admin.Empresas.CriarModel
@{
    ViewData["Title"] = "Nova empresa";
}

<div class="page-title">Nova empresa</div>
<div class="page-sub">Cadastre uma nova empresa conveniada</div>

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label class="form-label">Nome da empresa *</label>
            <input asp-for="NomeEmpresa" class="form-control" placeholder="Ex.: Indústria ABC" />
            <span asp-validation-for="NomeEmpresa" class="text-danger"></span>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">WhatsApp (número convênio)</label>
                <input asp-for="NumeroWhatsapp" class="form-control" placeholder="5512999999999" />
            </div>
            <div class="form-group">
                <label class="form-label">E-mail de acesso ao portal *</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="empresa@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Senha inicial *</label>
                <input asp-for="Senha" type="password" class="form-control" />
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Horário de corte do pedido</label>
                <input asp-for="HorarioCorte" type="time" class="form-control" />
                <span asp-validation-for="HorarioCorte" class="text-danger"></span>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Status</label>
            <select asp-for="Ativo" class="form-control" style="max-width:200px;">
                <option value="true">Ativa</option>
                <option value="false">Inativa</option>
            </select>
        </div>

        <div style="display:flex; gap:10px; margin-top:8px;">
            <button type="submit" class="btn btn-primary">Salvar empresa</button>
            <a href="/Admin/Empresas" class="btn">Cancelar</a>
        </div>
    </form>
</div>
